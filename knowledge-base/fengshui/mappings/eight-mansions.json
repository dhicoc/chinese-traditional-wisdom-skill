      "中性": ["伏位"],
      "凶": ["六煞", "祸害", "五鬼", "绝命"]
    },
    "star_meanings": {
      "生气": "贪狼木星，大吉。旺丁旺财，健康活力，最吉之星",
      "天医": "巨门土星，吉。健康长寿，贵人相助，祛病消灾",
      "延年": "武曲金星，吉。婚姻美满，家庭和睦，事业持久",
      "伏位": "辅弼木星，中性。平稳安定，适合休养生息，不宜进取",
      "绝命": "破军金星，大凶。健康受损，意外灾祸，最凶之星",
      "五鬼": "廉贞火星，凶。官司是非，火灾血光，突发变故",
      "六煞": "文曲水星，次凶。桃花纠纷，口舌是非，财运流失",
      "祸害": "禄存土星，凶。小人暗算，疾病纠缠，官非争执"
    }
  },

